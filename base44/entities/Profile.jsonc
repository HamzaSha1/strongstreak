{
  "name": "Profile",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string"
    },
    "display_name": {
      "type": "string"
    },
    "avatar_url": {
      "type": "string"
    },
    "bio": {
      "type": "string"
    },
    "is_private": {
      "type": "boolean",
      "default": false,
      "description": "Whether the profile is private or public"
    }
  },
  "required": [
    "user_id",
    "display_name"
  ]
}