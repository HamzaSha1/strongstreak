{
  "name": "SetLog",
  "type": "object",
  "properties": {
    "workout_log_id": {
      "type": "string"
    },
    "user_id": {
      "type": "string"
    },
    "exercise_name": {
      "type": "string"
    },
    "exercise_order": {
      "type": "number"
    },
    "set_number": {
      "type": "number"
    },
    "reps": {
      "type": "number"
    },
    "weight_kg": {
      "type": "number"
    },
    "rpe": {
      "type": "number"
    },
    "set_type": {
      "type": "string",
      "enum": [
        "normal",
        "dropset",
        "superset"
      ],
      "default": "normal"
    },
    "notes": {
      "type": "string"
    },
    "completed": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "workout_log_id",
    "user_id",
    "exercise_name"
  ],
  "rls": {
    "create": {
      "data.user_id": "{{user.email}}"
    },
    "read": {
      "data.user_id": "{{user.email}}"
    },
    "update": {
      "data.user_id": "{{user.email}}"
    },
    "delete": {
      "data.user_id": "{{user.email}}"
    }
  }
}